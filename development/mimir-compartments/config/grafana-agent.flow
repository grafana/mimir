                }],
                [{
                        __address__ = "alertmanager-3:8080",
                        cluster     = "docker-compose",
                        container   = "alertmanager",
                        job         = "mimir-compartments/alertmanager",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "block-builder-rc-0:8080",
                        cluster     = "docker-compose",
                        container   = "block-builder",
                        job         = "mimir-compartments/block-builder",
                        namespace   = "mimir-compartments",
                }, {
                        __address__ = "block-builder-rc-1:8080",
                        cluster     = "docker-compose",
