                        job         = "mimir-compartments/compactor",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "store-gateway-zone-a-rc-0:8080",
                        cluster     = "docker-compose",
                        container   = "store-gateway",
                        job         = "mimir-compartments/store-gateway",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "store-gateway-zone-b-rc-0:8080",
                        cluster     = "docker-compose",
                        container   = "store-gateway",
                        job         = "mimir-compartments/store-gateway",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "store-gateway-zone-a-rc-1:8080",
                        cluster     = "docker-compose",
                        container   = "store-gateway",
                        job         = "mimir-compartments/store-gateway",
