                }],
                [{
                        __address__ = "ruler-2:8080",
                        cluster     = "docker-compose",
                        container   = "ruler",
                        job         = "mimir-compartments/ruler",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ruler-3:8080",
                        cluster     = "docker-compose",
                        container   = "ruler",
                        job         = "mimir-compartments/ruler",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "alertmanager-1:8080",
                        cluster     = "docker-compose",
