prometheus.scrape "metrics_local_mimir_compartments" {
        targets = concat(
                [{
                        __address__ = "distributor-wc-0:8080",
                        cluster     = "docker-compose",
                        container   = "distributor",
                        job         = "mimir-compartments/distributor",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "distributor-wc-1:8080",
                        cluster     = "docker-compose",
                        container   = "distributor",
                        job         = "mimir-compartments/distributor",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-a-rc-0-0:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-a-rc-0-1:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-a-rc-1-0:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-a-rc-1-1:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-b-rc-0-0:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-b-rc-0-1:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-b-rc-1-0:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "ingester-zone-b-rc-1-1:8080",
                        cluster     = "docker-compose",
                        container   = "ingester",
                        job         = "mimir-compartments/ingester",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "querier:8080",
                        cluster     = "docker-compose",
                        container   = "querier",
                        job         = "mimir-compartments/querier",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "query-frontend:8080",
                        cluster     = "docker-compose",
                        container   = "query-frontend",
                        job         = "mimir-compartments/query-frontend",
                        namespace   = "mimir-compartments",
                }],
                [{
                        __address__ = "query-scheduler:8080",
