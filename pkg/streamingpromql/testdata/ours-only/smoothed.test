# These tests have been added here since upstream Prometheus has recently
# added support for smoothed/anchored histograms.
# These tests will be removed once our Mimir implementation is completed.

load 1s
  mixed 0 {{schema:0 sum:5 count:4 buckets:[1 2 1]}} 2 {{schema:0 sum:5 count:4 buckets:[1 2 1]}} 4 {{schema:0 sum:5 count:4 buckets:[1 2 1]}} 6 {{schema:0 sum:5 count:4 buckets:[1 2 1]}}

# MQE-only: instant `smoothed` over a series with histogram samples returns the histogram via
# exact match (t=1s) or lookback (t=8s). Prometheus's engine has a separate bug that panics on
# this expression (vendor/.../promql/engine.go:844 dereferences s.Floats[0] when both Floats and
# Histograms are empty), so these cases are kept here to skip Prometheus's engine.
eval instant at 1s mixed smoothed
  mixed {{schema:0 sum:5 count:4 buckets:[1 2 1]}}

eval instant at 8s mixed smoothed
  mixed {{schema:0 sum:5 count:4 buckets:[1 2 1]}}

# MQE-only (Prometheus panics on the empty result, see above): when the smoothed instant selector
# must interpolate between a look-back and look-ahead neighbour of different types it cannot, so it
# emits MixedFloatsHistogramsWarning and produces no point. This covers the histogram-then-float
# ordering: at 45s the look-back neighbour is the histogram at 30s and the look-ahead neighbour is
# the float at 60s.
clear
load 30s
  hist_then_float {{schema:0 sum:3 count:3 buckets:[3]}} {{schema:0 sum:4 count:4 buckets:[4]}} 1 2

eval instant at 45s hist_then_float smoothed
  expect warn msg: PromQL warning: encountered a mix of histograms and floats for metric name "hist_then_float"

# MQE-only: with multiple series in one selector, only the series whose neighbours mix floats and
# histograms is dropped (with the warning naming that series); a pure-float series is still
# interpolated. This exercises the per-series metric-name lookup used for the annotation.
clear
load 30s
  mm_mixed 1 2 {{schema:0 sum:3 count:3 buckets:[3]}} {{schema:0 sum:4 count:4 buckets:[4]}}
  mm_pure 10 20 30 40

eval instant at 45s {__name__=~"mm_mixed|mm_pure"} smoothed
  expect warn msg: PromQL warning: encountered a mix of histograms and floats for metric name "mm_mixed"
  mm_pure 25

# MQE-only (Prometheus panics on the empty result): when the smoothed instant selector interpolates
# between an exponential and a custom-bucket histogram it cannot, so it emits
# MixedExponentialCustomHistogramsWarning and produces no point. The upstream test covers the
# custom-then-exponential ordering; this covers the reverse (exponential at 30s, custom at 60s),
# confirming the schema check is order-independent and is not masked by the counter-reset path.
clear
load 30s
  exp_then_custom {{schema:0 sum:1 count:1 buckets:[1]}} {{schema:0 sum:1 count:1 buckets:[1]}} {{schema:-53 sum:1 count:1 custom_values:[5 10] buckets:[1]}} {{schema:-53 sum:1 count:1 custom_values:[5 10] buckets:[1]}}

eval instant at 45s histogram_count(exp_then_custom smoothed)
  expect warn msg: PromQL warning: vector contains a mix of histograms with exponential and custom buckets schemas for metric name "exp_then_custom"

# MQE-only, and a documented divergence from Prometheus's intent: the smoothed instant selector
# only inspects the two immediate neighbours of the eval time when deciding whether the window
# mixes floats and histograms. Here the nearest look-back (float @ 90s) and look-ahead (float @
# 110s) are both floats, so MQE interpolates and returns 100, even though a histogram sits at 50s
# within the look-back window. Prometheus's smoothSeries scans the full window and would emit
# MixedFloatsHistogramsWarning + drop the point - but its engine panics on the resulting empty
# instant result, so this can only be exercised against MQE. See the "Known limitation" note in
# instant_vector_selector.go.
clear
load 10s
  probe2b _ _ _ _ _ {{schema:0 sum:3 count:3 buckets:[3]}} _ _ _ 90 _ 110

eval instant at 100s probe2b smoothed
  expect no_warn
  probe2b 100
