# SPDX-License-Identifier: AGPL-3.0-only

# These tests exercise the experimental one-to-one 'fill', 'fill_left' and 'fill_right' binary
# operator modifiers. They are gated behind the parser's EnableBinopFillModifiers option, which the
# test runner enables for test files whose name contains "fill". Grouped (group_left/group_right)
# fills are not covered here.
#
# Semantics reference:
# https://promlabs.com/blog/2026/03/05/filling-in-missing-series-in-binary-operator-matching/.

# ---------- Partial overlap: default matching ----------

load 5m
  left_metric{label="a"} 10
  left_metric{label="b"} 20
  left_metric{label="c"} 30
  right_metric{label="a"} 100
  right_metric{label="b"} 200
  right_metric{label="d"} 400

# fill(0): fill both sides.
eval instant at 0m left_metric + fill(0) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="c"} 30
  {label="d"} 400

# fill_left(0): only fill left side, so only unmatched right-side groups get a result.
eval instant at 0m left_metric + fill_left(0) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="d"} 400

# fill_right(0): only fill right side, so only unmatched left-side groups get a result.
eval instant at 0m left_metric + fill_right(0) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="c"} 30

# fill_left and fill_right with different values.
eval instant at 0m left_metric + fill_left(5) fill_right(7) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="c"} 37
  {label="d"} 405

# fill with NaN.
eval instant at 0m left_metric + fill(NaN) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="c"} NaN
  {label="d"} NaN

# fill with Inf.
eval instant at 0m left_metric + fill(Inf) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="c"} +Inf
  {label="d"} +Inf

# fill with -Inf.
eval instant at 0m left_metric + fill(-Inf) right_metric
  {label="a"} 110
  {label="b"} 220
  {label="c"} -Inf
  {label="d"} -Inf

# ---------- Comparison operators with fill ----------

# Comparison filters keep the metric name of the present series for matched groups, but a filled
# series takes only the match-group labels (no metric name), matching upstream Caveat 2.
eval instant at 0m left_metric == fill(30) right_metric
  left_metric{label="c"} 30

eval instant at 0m left_metric != fill(30) right_metric
  left_metric{label="a"} 10
  left_metric{label="b"} 20
  {label="d"} 30

eval instant at 0m left_metric > fill(25) right_metric
  left_metric{label="c"} 30

# ---------- Comparison operators with bool modifier and fill ----------

eval instant at 0m left_metric == bool fill(30) right_metric
  {label="a"} 0
  {label="b"} 0
  {label="c"} 1
  {label="d"} 0

eval instant at 0m left_metric != bool fill(30) right_metric
  {label="a"} 1
  {label="b"} 1
  {label="c"} 0
  {label="d"} 1

eval instant at 0m left_metric > bool fill(25) right_metric
  {label="a"} 0
  {label="b"} 0
  {label="c"} 1
  {label="d"} 0

# ---------- fill with on() and ignoring() (one-to-one) ----------

clear

load 5m
  left_metric{job="foo", instance="a"} 10
  left_metric{job="foo", instance="b"} 20
  left_metric{job="bar", instance="c"} 30
  right_metric{job="foo", instance="a"} 100
  right_metric{job="foo", instance="d"} 300

# on(job, instance) keeps matching one-to-one because the (job, instance) pairs are unique.
eval instant at 0m left_metric + on(job, instance) fill(0) right_metric
  {job="foo", instance="a"} 110
  {job="foo", instance="b"} 20
  {job="bar", instance="c"} 30
  {job="foo", instance="d"} 300

eval instant at 0m left_metric + on(job, instance) fill_right(0) right_metric
  {job="foo", instance="a"} 110
  {job="foo", instance="b"} 20
  {job="bar", instance="c"} 30

eval instant at 0m left_metric + on(job, instance) fill_left(0) right_metric
  {job="foo", instance="a"} 110
  {job="foo", instance="d"} 300

# ignoring(job): the remaining labels (instance) are unique on each side, so still one-to-one.
eval instant at 0m left_metric + ignoring(job) fill(0) right_metric
  {instance="a"} 110
  {instance="b"} 20
  {instance="c"} 30
  {instance="d"} 300

eval instant at 0m left_metric + ignoring(job) fill_right(0) right_metric
  {instance="a"} 110
  {instance="b"} 20
  {instance="c"} 30

eval instant at 0m left_metric + ignoring(job) fill_left(0) right_metric
  {instance="a"} 110
  {instance="d"} 300

# ---------- No overlap at all ----------

clear

load 5m
  only_left{label="a"} 10
  only_left{label="b"} 20
  only_right{label="c"} 30
  only_right{label="d"} 40

# No overlap - fill creates all results.
eval instant at 0m only_left + fill(0) only_right
  {label="a"} 10
  {label="b"} 20
  {label="c"} 30
  {label="d"} 40

# No overlap - fill_left only creates right side results.
eval instant at 0m only_left + fill_left(0) only_right
  {label="c"} 30
  {label="d"} 40

# No overlap - fill_right only creates left side results.
eval instant at 0m only_left + fill_right(0) only_right
  {label="a"} 10
  {label="b"} 20

# ---------- Complete overlap ----------

clear

load 5m
  complete_left{label="a"} 10
  complete_left{label="b"} 20
  complete_right{label="a"} 100
  complete_right{label="b"} 200

# Complete overlap - fill has no effect.
eval instant at 0m complete_left + fill(99) complete_right
  {label="a"} 110
  {label="b"} 220

# ---------- Range queries ----------

clear

load 5m
  range_left{label="a"} 1 2 3 4 5
  range_left{label="b"} 10 20 30 40 50
  range_right{label="a"} 100 200 300 400 500
  range_right{label="c"} 1000 2000 3000 4000 5000

eval range from 0 to 20m step 5m range_left + fill(0) range_right
  {label="a"} 101 202 303 404 505
  {label="b"} 10 20 30 40 50
  {label="c"} 1000 2000 3000 4000 5000

eval range from 0 to 20m step 5m range_left + fill_right(0) range_right
  {label="a"} 101 202 303 404 505
  {label="b"} 10 20 30 40 50

eval range from 0 to 20m step 5m range_left + fill_left(0) range_right
  {label="a"} 101 202 303 404 505
  {label="c"} 1000 2000 3000 4000 5000

# ---------- Range queries where a group is present on only one side ----------

clear

load 5m
  side_left{label="a"}  1  2  3  4  5
  side_left{label="b"}  10 20 30 40 50
  side_right{label="a"} 100 200 300 400 500
  side_right{label="c"} 1000 2000 3000 4000 5000

# Group "b" exists only on the left; group "c" only on the right. fill_right keeps "b", fill_left keeps "c".
eval range from 0 to 20m step 5m side_left + fill_right(0) side_right
  {label="a"} 101 202 303 404 505
  {label="b"} 10 20 30 40 50

eval range from 0 to 20m step 5m side_left + fill_left(0) side_right
  {label="a"} 101 202 303 404 505
  {label="c"} 1000 2000 3000 4000 5000

# ---------- Range queries with intermittently present series (per-timestep fill) ----------
#
# Here a matched group's series are present on both sides but at *different* timesteps, so the fill
# must be applied per-timestep within the matched group: at each step where only one side has a
# sample, the other side takes the fill value (or is dropped, if that side is not being filled).

clear

load 5m
  intermittent_left{label="a"}  1  _  3  _  5
  intermittent_left{label="b"}  _  20 _  40 _
  intermittent_right{label="a"} _  200 _ 400 _
  intermittent_right{label="b"} 100 _  300 _ 500

# fill(0): output at every step where either side is present.
eval range from 0 to 20m step 5m intermittent_left + fill(0) intermittent_right
  {label="a"} 1 200 3 400 5
  {label="b"} 100 20 300 40 500

# fill_right(0): output only where the LEFT side is present (right filled with 0 if missing).
eval range from 0 to 20m step 5m intermittent_left + fill_right(0) intermittent_right
  {label="a"} 1 _ 3 _ 5
  {label="b"} _ 20 _ 40 _

# fill_left(0): output only where the RIGHT side is present (left filled with 0 if missing).
eval range from 0 to 20m step 5m intermittent_left + fill_left(0) intermittent_right
  {label="a"} _ 200 _ 400 _
  {label="b"} 100 _ 300 _ 500

# fill_left and fill_right with distinct values applied per-timestep within a matched group.
eval range from 0 to 20m step 5m intermittent_left + fill_left(7) fill_right(3) intermittent_right
  {label="a"} 4 207 6 407 8
  {label="b"} 107 23 307 43 507

# ---------- Trailing / leading-only presence (per-timestep fill at the extremes) ----------
#
# A matched group where one side only has a sample at the very first step and the other only at the
# very last step exercises the tail handling after one iterator is exhausted.

clear

load 5m
  edge_left{label="a"}  9 _ _ _ _
  edge_right{label="a"} _ _ _ _ 4

eval range from 0 to 20m step 5m edge_left + fill(0) edge_right
  {label="a"} 9 _ _ _ 4

eval range from 0 to 20m step 5m edge_left + fill_right(0) edge_right
  {label="a"} 9 _ _ _ _

eval range from 0 to 20m step 5m edge_left + fill_left(0) edge_right
  {label="a"} _ _ _ _ 4

# ---------- Comparison operators on intermittent data ----------

clear

load 5m
  cmp_left{label="a"}  5 _ 30 _ 5
  cmp_right{label="a"} _ 20 10 _ 50

# '>' with fill(0): at steps where only one side is present the missing operand is 0.
#   step 0: 5 > 0    -> keep 5   (right filled)
#   step 1: 0 > 20   -> dropped  (left filled)
#   step 2: 30 > 10  -> keep 30  (both present)
#   step 3: no data on either side
#   step 4: 5 > 50   -> dropped  (both present)
# As a comparison filter, the result keeps the left series' metric name at every step where a result
# is produced (including filled steps), matching upstream resultMetric behaviour.
eval range from 0 to 20m step 5m cmp_left > fill(0) cmp_right
  cmp_left{label="a"} 5 _ 30 _ _

# '>' with bool and fill(0): every step where at least one side is present yields 0 or 1.
eval range from 0 to 20m step 5m cmp_left > bool fill(0) cmp_right
  {label="a"} 1 0 1 _ 0

# fill_right only: output only where the left side is present (right filled with 0 if missing).
#   step 0: 5 > 0 -> 1; step 2: 30 > 10 -> 1; step 4: 5 > 50 -> 0.
eval range from 0 to 20m step 5m cmp_left > bool fill_right(0) cmp_right
  {label="a"} 1 _ 1 _ 0

# ---------- fill(NaN) / fill(Inf) at intermittent steps ----------

clear

load 5m
  special_left{label="a"}  1 _ 3 _ 5
  special_right{label="a"} _ 2 _ 4 _

# fill(NaN): filled steps produce NaN; matched steps have no overlap here so all steps are filled.
eval range from 0 to 20m step 5m special_left + fill(NaN) special_right
  {label="a"} NaN NaN NaN NaN NaN

# fill(Inf): left present + Inf on right -> +Inf; right present + Inf on left -> +Inf.
eval range from 0 to 20m step 5m special_left + fill(Inf) special_right
  {label="a"} +Inf +Inf +Inf +Inf +Inf

# fill_right(Inf): output only where left is present, right filled with +Inf.
eval range from 0 to 20m step 5m special_left * fill_right(Inf) special_right
  {label="a"} +Inf _ +Inf _ +Inf

# ---------- One side empty ----------

clear

load 5m
  non_empty{label="a"} 10
  non_empty{label="b"} 20

# Empty right side - fill_right has no effect (nothing to add).
eval instant at 0m non_empty + fill_right(0) nonexistent
  {label="a"} 10
  {label="b"} 20

# Empty right side - fill_left creates nothing (no right side labels to use).
eval instant at 0m non_empty + fill_left(0) nonexistent

# Empty left side - fill_left has no effect.
eval instant at 0m nonexistent + fill_left(0) non_empty
  {label="a"} 10
  {label="b"} 20

# Empty left side - fill_right creates nothing.
eval instant at 0m nonexistent + fill_right(0) non_empty

# fill both sides with one side empty.
eval instant at 0m non_empty + fill(0) nonexistent
  {label="a"} 10
  {label="b"} 20

eval instant at 0m nonexistent + fill(0) non_empty
  {label="a"} 10
  {label="b"} 20

# ---------- Native histogram present + float fill value ----------
#
# When the present side is a native histogram and the missing side is filled with a float, the
# arithmetic operator cannot combine a histogram with a float. The engine emits an "incompatible
# types" info annotation and drops that output point (no sample for that step / series).

clear

load 5m
  hist_left{label="a"}   {{schema:0 sum:5 count:4 buckets:[1 2 1]}}
  float_right{label="b"} 20

# fill(0): both sides filled.
#   {label="a"}: left histogram present, right missing -> filled with float 0 -> histogram + float is
#     incompatible, so the point is dropped (no output for this series).
#   {label="b"}: right float present, left missing -> filled with float 0 -> 0 + 20 = 20 (both float).
eval instant at 0m hist_left + fill(0) float_right
  {label="b"} 20
  expect info
  expect no_warn

# fill_right(0): only the right side is filled. The left histogram series has no right match, so its
# right operand is filled with float 0 -> histogram + float is incompatible -> point dropped. The
# unmatched right float series is not filled (fill_left is unset), so it produces no output.
eval instant at 0m hist_left + fill_right(0) float_right
  expect info
  expect no_warn

# fill_left(0): only the left side is filled. The unmatched right float series has its left operand
# filled with float 0 -> 0 + 20 = 20. The left histogram series is not filled, so no output for it.
eval instant at 0m hist_left + fill_left(0) float_right
  {label="b"} 20
  expect no_info
  expect no_warn
